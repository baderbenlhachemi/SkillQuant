rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Seeder helper ────────────────────────────────────────────────────────
    // The browser seeder (seeder.html) runs as an anonymous user and passes
    // _seederToken in every document.  We validate it here so normal users
    // can never write to these collections.
    // Change this token value whenever you rotate the seeder secret.
    function isSeeder() {
      return request.auth != null
          && request.resource.data._seederToken == "sq-seed-2026";
    }
    // Delete doesn't have request.resource — allow any authenticated seeder session
    function isSeederDelete() {
      return request.auth != null;
    }

    // Skills, metrics, opportunities, trending — read-only for authenticated users
    match /skills/{skillId} {
      allow read: if request.auth != null;
      allow create, update: if isSeeder();
      allow delete: if isSeederDelete();
    }

    match /skillMetrics/{skillId} {
      allow read: if request.auth != null;
      allow create, update: if isSeeder();
      allow delete: if isSeederDelete();

      match /history/{dateId} {
        allow read: if request.auth != null;
        allow create, update: if isSeeder();
        allow delete: if isSeederDelete();
      }
    }

    match /arbitrageOpportunities/{oppId} {
      allow read: if request.auth != null;
      allow create, update: if isSeeder();
      allow delete: if isSeederDelete();
    }

    match /trendingSkills/{trendId} {
      allow read: if request.auth != null;
      allow create, update: if isSeeder();
      allow delete: if isSeederDelete();
    }

    // Alerts — users can read/update their own alerts
    match /alerts/{alertId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false; // Only Cloud Functions create
    }

    // User profiles — users can read/write their own profile
    match /userProfiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['watchlist', 'notificationsEnabled', 'fcmToken',
                                 'displayName', 'email', 'isAnonymous',
                                 'darkThemeOverride', 'currentSkills', 'onboardingComplete']);
      allow delete: if false;
    }

    // App config — read-only
    match /appConfig/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Raw data collections — no client access
    match /rawJobPostings/{docId} {
      allow read, write: if false;
    }
    match /rawFreelanceGigs/{docId} {
      allow read, write: if false;
    }
    match /scrapeLogs/{docId} {
      allow read, write: if false;
    }
  }
}

