<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        SkillQuant — Diamond + Sparkline icon
        Diamond: center(54,52) half-size 48
        Top(54,4) Right(102,52) Bottom(54,100) Left(6,52)
        Sparkline: 4 points rising bottom-left → top-right, with one dip
        Peak: glowing teal dot top-right inside diamond
    -->

    <!-- ══ DIAMOND GLOW fills ══ -->
    <path android:pathData="M54,4 L102,52 L54,100 L6,52 Z"
        android:fillColor="#0900E5FF"/>
    <path android:pathData="M54,9 L97,52 L54,95 L11,52 Z"
        android:fillColor="#0D00E5FF"/>
    <path android:pathData="M54,14 L92,52 L54,90 L16,52 Z"
        android:fillColor="#1200E5FF"/>

    <!-- ══ DIAMOND STROKE ══ -->
    <path android:pathData="M54,4 L102,52 L54,100 L6,52 Z"
        android:strokeColor="#3800E5FF"
        android:strokeWidth="7"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M54,4 L102,52 L54,100 L6,52 Z"
        android:strokeColor="#FF00E5FF"
        android:strokeWidth="3.5"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- ══ SPARKLINE FILLED AREA (faint teal polygon) ══ -->
    <!--
        Sparkline points (inside diamond):
        P0(19,68)  P1(38,50)  P2(56,60)  P3(86,28)
        Closed back along baseline y=68
    -->
    <path
        android:pathData="M19,68 L38,50 L56,60 L86,28 L86,68 Z"
        android:fillColor="#1800E5FF"/>

    <!-- ══ SPARKLINE — white, 3 passes ══ -->
    <!-- Glow -->
    <path android:pathData="M19,68 L38,50 L56,60 L86,28"
        android:strokeColor="#3300E5FF"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>
    <!-- Main white line -->
    <path android:pathData="M19,68 L38,50 L56,60 L86,28"
        android:strokeColor="#EEFFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- ══ DATA DOTS on line (small white) ══ -->
    <path android:pathData="M19,68 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#AAFFFFFF"/>
    <path android:pathData="M38,50 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#AAFFFFFF"/>
    <path android:pathData="M56,60 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#AAFFFFFF"/>

    <!-- ══ PEAK GLOW DOT at (86,28) ══ -->
    <path android:pathData="M86,28 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0"
        android:fillColor="#2200E5FF"/>
    <path android:pathData="M86,28 m-6.5,0 a6.5,6.5 0 1,0 13,0 a6.5,6.5 0 1,0 -13,0"
        android:fillColor="#5500E5FF"/>
    <path android:pathData="M86,28 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"
        android:fillColor="#CC50F0FF"/>
    <path android:pathData="M86,28 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"
        android:fillColor="#FFFFFFFF"/>

    <!-- ══ DIAMOND VERTEX CAPS ══ -->
    <path android:pathData="M54,4 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"
        android:fillColor="#FF00E5FF"/>
    <path android:pathData="M102,52 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"
        android:fillColor="#FF00E5FF"/>
    <path android:pathData="M54,100 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"
        android:fillColor="#FF00E5FF"/>
    <path android:pathData="M6,52 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"
        android:fillColor="#FF00E5FF"/>

</vector>

